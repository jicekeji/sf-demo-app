# PostgreSQL connection string used by the backend at runtime.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mytodo

# HTTP port the API listens on.
PORT=8080

# Fail-closed session store: JSON map of opaque bearer tokens -> user ids.
# Requests must send `Authorization: Bearer <token>`; anything else is denied.
SESSIONS_JSON={"dev-token":"dev-user"}
